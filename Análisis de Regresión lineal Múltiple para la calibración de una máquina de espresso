#ANÁLISIS SENSORIAL DEL CAFÉ

library(readxl)

file.choose()

datos<- read_xlsx("")
View(datos)
attach(datos)

"Creación de la variable dependiente:
      CALIDAD DE LA ACIDEZ DEL ESPRESSO"

acidmodel <- lm(Acidez~Hora_del_dia+Gramos_de_Cafe+Mililitros_de_Espresso+Tiempo_de_Extraccion)

summary(acidmodel)

"Coefficients:
                       Estimate Std. Error t value Pr(>|t|)    
(Intercept)             6.67741    2.40016   2.782 0.038807 *  
Hora_del_dia            0.05373    0.02258   2.380 0.063181 .  
Gramos_de_Cafe          0.18322    0.13923   1.316 0.245285    
Mililitros_de_Espresso -0.19927    0.01886 -10.567 0.000131 ***
Tiempo_de_Extraccion    0.02222    0.01248   1.781 0.134939 "


library(ggplot2)

# Gráfico de la relación entre Hora del día y la Calidad de la Acidez del Espresso
ggplot(datos, aes(x = Hora_del_dia, y = Acidez)) +
  geom_point() +
  geom_smooth(method = "lm", col = "blue") +
  labs(title = "Relación entre Hora del día y la Calidad de la acidez del Espresso", 
       x = "Hora del día", y = "Calidad de la Acidez") +
  theme_minimal()

"La calidad de la acidez y su relación con la hora del día, va bajando conforme pasan las horas, sin embargo el
resumen del modelo propone que su relación no es significativa"



# Gráfico de la relación entre los Gramos de café y la Calidad de la Acidez del Espresso
ggplot(datos, aes(x = Gramos_de_Cafe, y = Acidez)) +
  geom_point() +
  geom_smooth(method = "lm", col = "green") +
  labs(title = "Relación entre los Gramos de café y la Calidad de la Acidez del Espresso", 
       x = "Gramos de café", y = "Calidad de la Acidez") +
  theme_minimal()

"La calidad de la acidez y su relación con el gramaje del café muestra una tendencia a bajar conforme aumenta el
gramaje, sin embargo el resumen del modelo propone que su relación no es significativa por lo que interpretamos que 
con la misma cantidad de gramaje se puede obtener una buena o una mala calidad de la acidez en el espresso"



# Gráfico de la relación entre los Mililitros de espresso y la Calidad de la acidez del Espresso
ggplot(datos, aes(x = Mililitros_de_Espresso, y = Acidez)) +
  geom_point() +
  geom_smooth(method = "lm", col = "red") +
  labs(title = "Relación entre los Mililitros de espresso y la Calidad de la acidez del Espresso", 
       x = "Mililitros de espresso", y = "Calidad de la Acidez") +
  theme_minimal()

"La calidad de la acidez del espresso y su relación con la cantidad de mililitros extraidos muestra una tendencia a
bajar conforme aumentan los mililitros de espresso, también el modelo propone que la relación tiene un nivel de
significancia alto por lo que la acidez está directamente relacionado con los mililitros extraidos"


# Gráfico de la relación entre el Tiempo de extracción y la Calidad de la Acidez del Espresso
ggplot(datos, aes(x = Tiempo_de_Extraccion, y = Acidez)) +
  geom_point() +
  geom_smooth(method = "lm", col = "purple") +
  labs(title = "Relación entre el Tiempo de extracción y la Calidad de la Acidez del Espresso", 
       x = "Tiempo de extracción", y = "Calidad de la Acidez") +
  theme_minimal()


"La relación entre la calidad de la acidez del Espresso y el tiempo de extracción muestra una tendencia a bajar 
y es la segunda variable con más significancia por lo que hay que prestar especial atención al tiempo de extracción"





